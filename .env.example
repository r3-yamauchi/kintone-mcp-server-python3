# kintone MCP Server (Python3) 設定ファイル

# 認証タイプ: "api_token" または "password"
KINTONE_AUTH_TYPE=api_token

# kintone サブドメイン（必須）
# 例: kintone URLが https://example.cybozu.com の場合、サブドメインは "example"
KINTONE_SUBDOMAIN=your-subdomain

# kintone ドメイン（オプション、デフォルト: cybozu.com）
# 米国データセンターの場合は "kintone.com"
# 中国の場合は "cybozu.cn"
KINTONE_DOMAIN=cybozu.com

# APIトークン認証の場合
# kintoneアプリの設定画面からAPIトークンを生成
KINTONE_API_TOKEN=your-api-token-here

# パスワード認証の場合（APIトークンの代替）
# KINTONE_AUTH_TYPE=password
# KINTONE_USERNAME=your-username@example.com
# KINTONE_PASSWORD=your-password

# ログレベル（オプション）
# 値: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO